{
  "private": true,
  "description": "Zero-dependency, TypeScript-first event bus with plugin architecture",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm run lint && pnpm run format:check && pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:watch": "pnpm -r run test:watch",
    "typecheck": "pnpm -r run typecheck",
    "badge": "node scripts/generate-coverage-badge.mjs",
    "prepare": "git config core.hooksPath hooks",
    "example": "pnpm --filter tiny-event-bus-react-demo run dev",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.0.0"
  }
}
