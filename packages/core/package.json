{
  "name": "@tiny-event-bus/core",
  "version": "0.10.0",
  "description": "Zero-dependency, TypeScript-first event bus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vineet2907/tiny-event-bus.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/vineet2907/tiny-event-bus/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/vineet2907/tiny-event-bus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "rm -rf dist && pnpm run build:esm && pnpm run build:cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "event-bus",
    "events",
    "pubsub",
    "typescript",
    "signals"
  ]
}
