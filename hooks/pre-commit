#!/bin/sh

# Scan staged changes for secrets using gitleaks.
# Requires gitleaks to be installed locally (brew install gitleaks).
# If gitleaks is not installed, the hook is skipped with a warning.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo ""
  echo "Warning: gitleaks is not installed. Skipping secret scan."
  echo "Install with: brew install gitleaks"
  echo ""
  exit 0
fi

gitleaks git --pre-commit --staged --no-banner
